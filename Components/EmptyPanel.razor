@using ESLViewer.Models
@using ESLViewer.Services
@inject DragDropService DragDrop
@inject IJSRuntime JS

<div class="empty-panel @(_dragOver ? "drag-over" : "")"
     @ondragenter="OnDragEnter"
     @ondragover="OnDragOver" @ondragover:preventDefault="true"
     @ondragleave="OnDragLeave"
     @ondrop="OnDropAsync">

    <div class="empty-panel-content">
        <div class="dropdown">
            <button id="ep-btn-@_id"
                    class="btn btn-primary btn-sm dropdown-toggle"
                    data-bs-toggle="dropdown" aria-expanded="false">
                Add New
            </button>
            <ul class="dropdown-menu">
                <li>
                    <button class="dropdown-item" @onclick='() => ReplaceWith(PanelType.Numeric)'>
                        📈 Numeric
                    </button>
                </li>
                <li>
                    <button class="dropdown-item" @onclick='() => ReplaceWith(PanelType.DateTime)'>
                        📅 DateTime
                    </button>
                </li>
                <li>
                    <button class="dropdown-item" @onclick='() => ReplaceWith(PanelType.Grid)'>
                        🔲 Grid
                    </button>
                </li>
                <li>
                    <button class="dropdown-item" @onclick='() => ReplaceWith(PanelType.Dashboard)'>
                        🖥 Dashboard
                    </button>
                </li>
                <li>
                    <button class="dropdown-item" @onclick='() => ReplaceWith(PanelType.Table)'>
                        📊 Table
                    </button>
                </li>
                @if (Model.CanBeClosed)
                {
                    <li><hr class="dropdown-divider" /></li>
                    <li>
                        <button class="dropdown-item text-danger" @onclick="() => OnRemove.InvokeAsync(Model)">
                            ✕ Remove
                        </button>
                    </li>
                }
            </ul>
        </div>
    </div>
</div>

@code {
    [Parameter] public PanelModel Model { get; set; } = default!;
    [Parameter] public EventCallback<PanelModel> OnRemove { get; set; }
    [Parameter] public EventCallback<PanelType> OnReplace { get; set; }
    [Parameter] public EventCallback<PanelModel> OnDropPanel { get; set; }
    [Parameter] public bool DisableDrop { get; set; }

    private bool _dragOver;
    private readonly string _id = Guid.NewGuid().ToString("N")[..8];

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            // Re-initialize the Bootstrap dropdown with position:fixed so it
            // isn't clipped by ancestor overflow:hidden containers (#dropdown-clip-fix)
            try { await JS.InvokeVoidAsync("ESLViewer.initFixedDropdown", $"ep-btn-{_id}"); }
            catch { /* JS not ready — Bootstrap auto-init will handle it */ }
        }
    }

    private Task ReplaceWith(PanelType type) => OnReplace.InvokeAsync(type);

    // Using ondragenter to re-set _dragOver when entering a child element,
    // preventing false dragleave flicker (#19)
    private void OnDragEnter(DragEventArgs _)
    {
        if (DragDrop.IsDragging && !DisableDrop)
            _dragOver = true;
    }

    private void OnDragOver(DragEventArgs _)
    {
        if (DragDrop.IsDragging && !DisableDrop)
            _dragOver = true;
    }

    private void OnDragLeave() => _dragOver = false;

    private async Task OnDropAsync()
    {
        _dragOver = false;
        if (DisableDrop) return;
        var dropped = await DragDrop.CompleteDrop();
        if (dropped is not null)
            await OnDropPanel.InvokeAsync(dropped);
    }
}
