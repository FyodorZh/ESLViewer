@using ESLViewer.Models
@inject DragDropService DragDrop
@inject IJSRuntime JS
@implements IAsyncDisposable

<div class="grid-panel">
    <div class="panel-header">
        @if (Model.CanBeClosed)
        {
            <span class="drag-handle" draggable="true"
                  @ondragstart="OnDragStart" @ondragend="OnDragEnd"
                  title="Drag to move panel">⠿</span>
        }
        <input class="panel-title-input" type="text" @bind="Model.Title" @bind:event="oninput" />
        <span class="panel-header-spacer"></span>
        <div class="grid-panel-header-controls">
            <span class="panel-type-badge">Grid @(Model.XSize)×@(Model.YSize)</span>
            <button class="btn-sm btn-primary grid-btn" title="Add row" @onclick="AddRow">+Row</button>
            <button class="btn-sm btn-primary grid-btn" title="Add column" @onclick="AddColumn">+Col</button>
            <button class="btn-sm btn-secondary grid-btn" title="Remove bottom row (only when all empty)"
                    @onclick="RemoveRow" disabled="@(!Model.CanRemoveRow())">−Row</button>
            <button class="btn-sm btn-secondary grid-btn" title="Remove rightmost column (only when all empty)"
                    @onclick="RemoveColumn" disabled="@(!Model.CanRemoveColumn())">−Col</button>
            @if (Model.CanBeClosed)
            {
                <button class="btn-icon btn-danger" title="Remove panel" @onclick="() => OnRemove.InvokeAsync(Model)">&#x2715;</button>
            }
        </div>
    </div>

    <div class="grid-panel-cells"
         id="grid-cells-@Model.Id"
         style="display:grid;
                grid-template-columns: @GetGridColumns();
                grid-template-rows: @GetGridRows();
                gap:8px; padding:4px; overflow:hidden; position:relative;">
        @foreach (var cell in Model.Cells)
        {
            var currentCell = cell;
            @if (currentCell is GridPanelModel nestedGrid)
            {
                <GridPanel Model="nestedGrid"
                           OnRemove="m => ReplaceCellWithEmpty(m)"
                           OnReplaceWithEmpty="ReplaceCellWithEmpty"
                           DisableAllDrops="@IsBeingDragged"
                           @ref="_gridCellRefs[nestedGrid.Id]" />
            }
            else if (currentCell is DashboardPanelModel dashCell)
            {
                <DashboardPanel Model="dashCell"
                                OnRemove="m => ReplaceCellWithEmpty(m)"
                                OnReplaceWithEmpty="ReplaceCellWithEmpty"
                                @ref="_dashboardCellRefs[dashCell.Id]" />
            }
            else if (currentCell.PanelType == PanelType.Empty)
            {
                <EmptyPanel Model="currentCell"
                            OnRemove="m => ReplaceCellWithEmpty(m)"
                            OnReplace="type => ReplaceCell(currentCell, type)"
                            OnDropPanel="model => HandleCellDrop(currentCell, model)"
                            DisableDrop="@(IsBeingDragged || DisableAllDrops)" />
            }
            else
            {
                <Panel Model="currentCell"
                       OnRemove="m => ReplaceCellWithEmpty(m)"
                       OnReplaceWithEmpty="ReplaceCellWithEmpty"
                       @ref="_cellRefs[currentCell.Id]" />
            }
        }
    </div>
</div>

@code {
    [Parameter] public GridPanelModel Model { get; set; } = default!;
    [Parameter] public EventCallback<PanelModel> OnRemove { get; set; }
    [Parameter] public EventCallback<PanelModel> OnReplaceWithEmpty { get; set; }

    /// <summary>
    /// When true, all EmptyPanel descendants disable drop (set by the parent when THIS grid is being dragged).
    /// </summary>
    [Parameter] public bool DisableAllDrops { get; set; }

    private Dictionary<Guid, Panel?> _cellRefs = new();
    private Dictionary<Guid, GridPanel?> _gridCellRefs = new();
    private Dictionary<Guid, DashboardPanel?> _dashboardCellRefs = new();

    private DotNetObjectReference<GridPanel>? _dotNetRef;

    private bool IsBeingDragged => DragDrop.IsDragging && DragDrop.DraggedPanel?.Id == Model.Id;

    // ── Grid columns/rows CSS ─────────────────────────────────────────────────

    private string GetGridColumns() =>
        string.Join(" ", Model.GetColumnFractions().Select(f => $"{f:F4}fr"));

    private string GetGridRows() =>
        string.Join(" ", Model.GetRowFractions().Select(f => $"{f:F4}fr"));

    // ── Lifecycle ─────────────────────────────────────────────────────────────

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            // Ensure refs exist before we try to access them
            foreach (var cell in Model.Cells)
            {
                if (cell is GridPanelModel g) _gridCellRefs.TryAdd(g.Id, null);
                else if (cell is DashboardPanelModel d) _dashboardCellRefs.TryAdd(d.Id, null);
                else _cellRefs.TryAdd(cell.Id, null);
            }
        }
        await InitResizersAsync();
    }

    private async Task InitResizersAsync()
    {
        if (_dotNetRef is null)
            _dotNetRef = DotNetObjectReference.Create(this);
        try
        {
            await JS.InvokeVoidAsync("ESLViewer.initGridResizers",
                $"grid-cells-{Model.Id}", Model.MinWidth, _dotNetRef);
        }
        catch { /* ignore if JS not ready */ }
    }

    [JSInvokable]
    public void OnResizeComplete(double[] colFracs, double[] rowFracs)
    {
        // Guard against stale JS calls if the grid was resized between drag start and end
        if (colFracs.Length == Model.XSize)
            Model.ColumnFractions = colFracs;
        if (rowFracs.Length == Model.YSize)
            Model.RowFractions = rowFracs;
        // No StateHasChanged — CSS already updated by JS; model updated for next snapshot.
    }

    // ── Cell mutations ────────────────────────────────────────────────────────

    private void AddRow()
    {
        Model.AddRow();
        StateHasChanged();
    }

    private void AddColumn()
    {
        Model.AddColumn();
        StateHasChanged();
    }

    private void RemoveRow()
    {
        Model.RemoveRow();
        CleanupStaleRefs();
        StateHasChanged();
    }

    private void RemoveColumn()
    {
        Model.RemoveColumn();
        CleanupStaleRefs();
        StateHasChanged();
    }

    /// <summary>Replace an EmptyPanel cell with a new panel of the given type.</summary>
    private void ReplaceCell(PanelModel oldCell, PanelType type)
    {
        var idx = Model.Cells.IndexOf(oldCell);
        if (idx < 0) return;

        _cellRefs.Remove(oldCell.Id);
        _gridCellRefs.Remove(oldCell.Id);
        _dashboardCellRefs.Remove(oldCell.Id);

        PanelModel newCell = type switch
        {
            PanelType.Grid      => new GridPanelModel(),
            PanelType.Dashboard => new DashboardPanelModel(),
            _                   => new PanelModel { Title = "Panel", PanelType = type }
        };

        Model.Cells[idx] = newCell;
        if (newCell is GridPanelModel ng) _gridCellRefs[ng.Id] = null;
        else if (newCell is DashboardPanelModel nd) _dashboardCellRefs[nd.Id] = null;
        else _cellRefs[newCell.Id] = null;
        StateHasChanged();
    }

    /// <summary>Replace a non-empty cell with a fresh EmptyPanel (triggered by the cell's remove button).</summary>
    private void ReplaceCellWithEmpty(PanelModel model)
    {
        var idx = Model.Cells.IndexOf(model);
        if (idx < 0) return;

        _cellRefs.Remove(model.Id);
        _gridCellRefs.Remove(model.Id);
        _dashboardCellRefs.Remove(model.Id);
        var empty = new PanelModel { PanelType = PanelType.Empty, CanBeClosed = false };
        Model.Cells[idx] = empty;
        _cellRefs[empty.Id] = null;
        StateHasChanged();
    }

    /// <summary>Accept a dropped panel at an empty cell position.</summary>
    private void HandleCellDrop(PanelModel emptyCell, PanelModel droppedPanel)
    {
        var idx = Model.Cells.IndexOf(emptyCell);
        if (idx < 0) return;

        _cellRefs.Remove(emptyCell.Id);
        _gridCellRefs.Remove(emptyCell.Id);
        _dashboardCellRefs.Remove(emptyCell.Id);

        Model.Cells[idx] = droppedPanel;
        if (droppedPanel is GridPanelModel dg) _gridCellRefs[dg.Id] = null;
        else if (droppedPanel is DashboardPanelModel dd) _dashboardCellRefs[dd.Id] = null;
        else _cellRefs[droppedPanel.Id] = null;
        StateHasChanged();
    }

    private void CleanupStaleRefs()
    {
        var ids = Model.Cells.Select(c => c.Id).ToHashSet();
        foreach (var key in _cellRefs.Keys.ToList())
            if (!ids.Contains(key)) _cellRefs.Remove(key);
        foreach (var key in _gridCellRefs.Keys.ToList())
            if (!ids.Contains(key)) _gridCellRefs.Remove(key);
        foreach (var key in _dashboardCellRefs.Keys.ToList())
            if (!ids.Contains(key)) _dashboardCellRefs.Remove(key);
    }

    // ── Drag ──────────────────────────────────────────────────────────────────

    private void OnDragStart()
    {
        DragDrop.StartDrag(Model, () => OnReplaceWithEmpty.InvokeAsync(Model));
    }

    private void OnDragEnd()
    {
        if (DragDrop.IsDragging) DragDrop.Cancel();
    }

    // ── Public API (used by PanelGrid) ────────────────────────────────────────

    /// <summary>Refresh all nested data panels (and nested grids) recursively.</summary>
    public async Task RefreshAllAsync()
    {
        foreach (var (_, panelRef) in _cellRefs)
            if (panelRef is not null) await panelRef.RefreshAsync();
        foreach (var (_, gridRef) in _gridCellRefs)
            if (gridRef is not null) await gridRef.RefreshAllAsync();
        foreach (var (_, dashRef) in _dashboardCellRefs)
            if (dashRef is not null) await dashRef.RefreshAsync();
    }

    /// <summary>Capture a full snapshot including nested panels' axis ranges.</summary>
    public async Task<PanelSnapshot> CaptureSnapshotAsync()
    {
        var snapshot = Model.ToSnapshot();
        for (int i = 0; i < Model.Cells.Count; i++)
        {
            var cell = Model.Cells[i];
            if (cell is GridPanelModel && _gridCellRefs.TryGetValue(cell.Id, out var gridRef) && gridRef is not null)
                snapshot.GridCells[i] = await gridRef.CaptureSnapshotAsync();
            else if (cell is DashboardPanelModel && _dashboardCellRefs.TryGetValue(cell.Id, out var dashRef) && dashRef is not null)
                snapshot.GridCells[i] = dashRef.CaptureSnapshot();
            else if (cell.PanelType != PanelType.Empty && _cellRefs.TryGetValue(cell.Id, out var panelRef) && panelRef is not null)
                snapshot.GridCells[i] = await panelRef.CaptureSnapshotAsync();
        }
        return snapshot;
    }

    public async ValueTask DisposeAsync()
    {
        try
        {
            await JS.InvokeVoidAsync("ESLViewer.cleanupGridResizers", $"grid-cells-{Model.Id}");
        }
        catch { }
        _dotNetRef?.Dispose();
    }
}
