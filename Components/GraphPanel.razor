@using ESLViewer.Models
@using ESLViewer.Models.State
@using ESLViewer.Services
@using ApexCharts
@inject MathServerService MathServer
@inject IJSRuntime JS
@inject DragDropService DragDrop
@implements IAsyncDisposable

@if (_isFullscreen)
{
    <div class="panel-fullscreen-backdrop" @onclick="ToggleFullscreen"></div>
}
<div class="panel @(_isFullscreen ? "panel-fullscreen" : "")">
    <div class="panel-header">
        <span class="drag-handle" draggable="true"
              @ondragstart="OnDragStart" @ondragend="OnDragEnd"
              title="Drag to move panel">⠿</span>
        <input class="panel-title-input" type="text" @bind="Model.Title" @bind:event="oninput" />
        <span class="panel-header-spacer"></span>
        <label class="panel-ar-label">
            <input type="checkbox"
                   checked="@_ar.IsEnabled"
                   @onchange="OnAutoRefreshToggled" />
            Auto-refresh
        </label>
        @if (_ar.IsEnabled)
        {
            <select class="ar-select panel-ar-select" value="@_ar.Interval" @onchange="OnIntervalChanged">
                <option value="Second1">1 s</option>
                <option value="Seconds3">3 s</option>
                <option value="Seconds5">5 s</option>
                <option value="Seconds10">10 s</option>
                <option value="Minute1">1 min</option>
                <option value="Minute10">10 min</option>
                <option value="Hour1">1 hour</option>
            </select>
            <span class="ar-active-dot" title="Auto-refresh active"></span>
        }
        <span class="panel-type-badge">@Model.PanelType</span>
        <button class="btn-icon" title="Configure" @onclick="ToggleConfig">&#x2699;</button>
        <button class="btn-icon" title="@(_isFullscreen ? "Exit fullscreen" : "Fullscreen")" @onclick="ToggleFullscreen">@(_isFullscreen ? "⊡" : "⛶")</button>
        @if (!_isFullscreen)
        {
            <button class="btn-icon btn-danger" title="Remove panel" @onclick="() => OnRemove.InvokeAsync(Model)">&#x2715;</button>
        }
    </div>

    <div class="panel-chart-area" id="chart-container-@Model.Id">
        @if (_loading)
        {
            <div class="panel-loading">Loading&#8230;</div>
        }

        <ApexChart TItem="PanelPoint"
                   Title=""
                   @ref="_chart"
                   Options="_options"
                   Width="@("100%")"
                   Height="@("100%")"
                   @key="_chartKey">
            @if (Model.PanelType == PanelType.DateTime)
            {
                @foreach (var expr in _enabledExpressions)
                {
                    var e = expr;
                    <ApexPointSeries TItem="PanelPoint"
                                     Items="e.Points"
                                     Name="@(string.IsNullOrWhiteSpace(e.Label) ? e.Expression : e.Label)"
                                     SeriesType="SeriesType.Line"
                                     XValue="p => (long)p.X"
                                     YValue="p => (decimal)p.Y"
                                     Color="@e.Color"
                                     OrderBy="d => d.X" />
                }
            }
            else
            {
                @foreach (var expr in _enabledExpressions)
                {
                    var e = expr;
                    <ApexPointSeries TItem="PanelPoint"
                                     Items="e.Points"
                                     Name="@(string.IsNullOrWhiteSpace(e.Label) ? e.Expression : e.Label)"
                                     SeriesType="SeriesType.Line"
                                     XValue="p => (decimal)p.X"
                                     YValue="p => (decimal)p.Y"
                                     Color="@e.Color"
                                     OrderBy="d => d.X" />
                }
            }
        </ApexChart>
    </div>

    @if (_showConfig)
    {
        <ExpressionEditor Expressions="Model.Expressions"
                          PanelType="Model.PanelType"
                          OnRefresh="RefreshOneAsync"
                          OnColorChanged="UpdateChartManual" />
    }
</div>

@code {
    [Parameter] public GraphPanelModel Model { get; set; } = default!;
    [Parameter] public EventCallback<PanelModel> OnRemove { get; set; }
    [Parameter] public EventCallback<PanelModel> OnReplaceWithEmpty { get; set; }

    private ApexChart<PanelPoint>? _chart;
    private ApexChartOptions<PanelPoint> _options = new();
    private List<ExpressionModel> _enabledExpressions = new();
    private bool _loading;
    private int _chartKey;
    private bool _needsChartRender;
    private bool _animateNextRender = true;   // controls fade-in on next deferred render
    private bool _chartReady;
    private bool _showConfig = true;
    private bool _isFullscreen;

    // Auto-refresh controller
    private readonly AutoRefreshController _ar = new();

    protected override void OnInitialized()
    {
        _ar.Initialize(Model.AutoRefreshEnabled, Model.AutoRefreshInterval);

        _options = new ApexChartOptions<PanelPoint>
        {
            Chart = new Chart
            {
                Zoom = new Zoom { Enabled = true, Type = AxisType.Xy },
                Toolbar = new Toolbar { Show = true, AutoSelected = AutoSelected.Zoom },
                Animations = new Animations
                {
                    DynamicAnimation = new DynamicAnimation { Enabled = true, Speed = 350 }
                }
            },
            Xaxis = new XAxis
            {
                Type = Model.PanelType == PanelType.DateTime ? XAxisType.Datetime : XAxisType.Numeric
            },
            Yaxis = new List<YAxis>
            {
                new YAxis
                {
                    Labels = new YAxisLabels
                    {
                        Formatter = "function(val) { return parseFloat(val.toPrecision(12)).toString(); }"
                    }
                }
            },
            Stroke = new Stroke { Curve = Curve.Straight, Width = new List<int> { 2 } },
            Markers = new Markers { Size = new List<int> { 0 } },
            Legend = new Legend { Show = true, Position = LegendPosition.Bottom }
        };

        if (Model.Expressions.Count == 0)
        {
            var defaultExpr = string.Empty;
            Model.Expressions.Add(new ExpressionModel { Expression = defaultExpr, Color = "#1b6ec2", Label = "f1" });
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            _chartReady = true;
            await RefreshAsync(animate: true);
            if (_ar.IsEnabled)
                _ar.Start(token => RefreshAsync(token, animate: false));
        }
        else if (_needsChartRender && _chartReady)
        {
            _needsChartRender = false;
            if (_chart is not null)
            {
                try
                {
                    await ApplyAnimationAsync(_animateNextRender);
                    await _chart.RenderAsync();
                }
                catch
                {
                    // ApexChart JS not ready yet – retry on the next render cycle
                    _needsChartRender = true;
                }
            }
        }
    }

    // Called by ExpressionEditor: expr == null means refresh all
    private async Task RefreshOneAsync(ExpressionModel? expr)
    {
        if (expr is not null)
            await RefreshAsync(expr, animate: true);
        else
            await RefreshAsync(animate: true);
    }

    // Refresh a single expression only
    private async Task RefreshAsync(ExpressionModel expr, CancellationToken token = default, bool animate = true)
    {
        _loading = true;
        StateHasChanged();

        if (!string.IsNullOrWhiteSpace(expr.Expression))
            expr.Points = await MathServer.EvaluateAsync(expr.Expression, Model.PanelType, token);

        _loading = false;
        await UpdateChart(animate);
    }

    // Refresh all expressions
    public async Task RefreshAsync(CancellationToken token = default, bool animate = true)
    {
        _loading = true;
        StateHasChanged();

        foreach (var expr in Model.Expressions)
        {
            if (!string.IsNullOrWhiteSpace(expr.Expression))
                expr.Points = await MathServer.EvaluateAsync(expr.Expression, Model.PanelType, token);
        }

        _loading = false;
        await UpdateChart(animate);
    }

    private async Task UpdateChart(bool animate = true)
    {
        _animateNextRender = animate;
        _enabledExpressions = Model.Expressions
            .Where(e => e.IsEnabled && e.Points.Count > 0)
            .ToList();

        if (_enabledExpressions.Count == 0)
        {
            _needsChartRender = false;
            _chartKey++;
            StateHasChanged();
            return;
        }

        _needsChartRender = true;
        StateHasChanged();

        if (_chart is not null && _chartReady)
        {
            try
            {
                await ApplyAnimationAsync(animate);
                await _chart.RenderAsync();
                _needsChartRender = false;
            }
            catch
            {
                // ApexChart JS not ready yet – _needsChartRender stays true, retried in OnAfterRenderAsync
            }
        }
    }

    /// No-arg wrapper so UpdateChart can be passed as EventCallback (e.g. OnColorChanged).
    private Task UpdateChartManual() => UpdateChart(animate: true);

    /// Pushes the animation enabled/disabled setting directly to the live ApexChart instance.
    private async Task ApplyAnimationAsync(bool enabled)
    {
        try
        {
            await JS.InvokeVoidAsync("ESLViewer.setChartAnimation",
                $"chart-container-{Model.Id}", enabled);
        }
        catch { }
    }

    /// Helper: sets DynamicAnimation.Enabled on _options.Chart.Animations (for initial setup).
    private void SetAnimationEnabled(bool enabled)
    {
        if (_options.Chart?.Animations?.DynamicAnimation is not null)
            _options.Chart.Animations.DynamicAnimation.Enabled = enabled;
    }

    // ── Auto-refresh ──────────────────────────────────────────────────────────

    private void OnAutoRefreshToggled(ChangeEventArgs e)
    {
        _ar.Toggle((bool)(e.Value ?? false), token => RefreshAsync(token, animate: false));
        Model.AutoRefreshEnabled = _ar.IsEnabled;
    }

    private void OnIntervalChanged(ChangeEventArgs e)
    {
        if (Enum.TryParse<AutoRefreshInterval>(e.Value?.ToString(), out var interval))
        {
            _ar.ChangeInterval(interval);
            Model.AutoRefreshInterval = _ar.Interval;
        }
    }

    private void ToggleConfig() => _showConfig = !_showConfig;

    private void ToggleFullscreen()
    {
        _isFullscreen = !_isFullscreen;
        _chartKey++; // force ApexChart remount to recalculate size
    }

    // ── Snapshot / ViewRect interop ───────────────────────────────────────────

    public async Task<ViewRect> GetViewRect()
    {
        try
        {
            var result = await JS.InvokeAsync<ViewRect?>(
                "ESLViewer.getChartAxisRange", $"chart-container-{Model.Id}");
            return result ?? new ViewRect();
        }
        catch
        {
            return new ViewRect();
        }
    }

    public async Task SetViewRect(ViewRect rect)
    {
        try
        {
            await JS.InvokeVoidAsync(
                "ESLViewer.setChartAxisRange",
                $"chart-container-{Model.Id}",
                rect.XMin, rect.XMax,
                rect.YMin, rect.YMax);
        }
        catch { }
    }

    public async Task<PanelSnapshot> CaptureSnapshotAsync()
    {
        Model.AutoRefreshEnabled = _ar.IsEnabled;
        Model.AutoRefreshInterval = _ar.Interval;
        var snapshot = Model.ToSnapshot();
        snapshot.ViewRect = await GetViewRect();
        return snapshot;
    }

    // ── Drag ──────────────────────────────────────────────────────────────────

    private void OnDragStart()
        => DragDrop.StartDrag(Model, () => OnReplaceWithEmpty.InvokeAsync(Model));

    private void OnDragEnd()
    {
        if (DragDrop.IsDragging) DragDrop.Cancel();
    }

    public async ValueTask DisposeAsync()
    {
        await _ar.DisposeAsync();
    }
}

