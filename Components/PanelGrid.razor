@using ESLViewer.Models
@using ESLViewer.Models.State
@using ESLViewer.Services
@inject StateService StateService
@inject IJSRuntime JS
@implements IAsyncDisposable

<div class="panel-grid-toolbar">
    <label>
        Columns:
        <select @bind="_columns">
            <option value="1">1</option>
            <option value="2">2</option>
            <option value="3">3</option>
            <option value="4">4</option>
        </select>
    </label>
    <label>
        Panel size:
        <input type="range" min="280" max="900" step="20" @bind="_panelSize" />
        <span>@_panelSize px</span>
    </label>
    <div class="dropdown d-inline-block">
        <button class="btn-sm btn-primary dropdown-toggle" data-bs-toggle="dropdown" aria-expanded="false">
            + Add panel
        </button>
        <ul class="dropdown-menu">
            <li><button class="dropdown-item" @onclick='() => AddPanel(PanelType.Numeric)'>📈 Numeric</button></li>
            <li><button class="dropdown-item" @onclick='() => AddPanel(PanelType.DateTime)'>📅 DateTime</button></li>
        </ul>
    </div>

    <div class="d-inline-flex gap-1 ms-3 align-items-center flex-wrap">
        <button class="btn-sm btn-outline-secondary" title="Save state to cookie" @onclick="SaveToCookieAsync">🍪 Save</button>
        <button class="btn-sm btn-outline-secondary" title="Restore state from cookie" @onclick="LoadFromCookieAsync">🍪 Load</button>
        <button class="btn-sm btn-outline-secondary" title="Copy state to clipboard" @onclick="CopyToClipboardAsync">📋 Copy</button>
        <button class="btn-sm btn-outline-secondary" title="Paste state from clipboard" @onclick="PasteFromClipboardAsync">📋 Paste</button>
        <button class="btn-sm btn-outline-secondary" title="Download state as JSON" @onclick="DownloadJsonAsync">⬇ JSON</button>
        <label class="btn-sm btn-outline-secondary mb-0" title="Load state from JSON file" style="cursor:pointer">
            ⬆ Open
            <InputFile OnChange="LoadFromFileAsync" accept=".json" style="display:none" />
        </label>
    </div>

    @if (_statusMessage is not null)
    {
        <span class="ms-2 small @(_statusIsError ? "text-danger" : "text-success")">@_statusMessage</span>
    }
</div>

<a id="state-download-link" href="@_downloadUrl" download="eslviewer-state.json" style="display:none"></a>

<div class="panel-grid" style="grid-template-columns: repeat(@_columns, @(_panelSize)px);">
    @foreach (var panel in _panels)
    {
        var current = panel;
        <Panel Model="current"
               Width="_panelSize"
               Height="@(_panelSize - 80)"
               OnRemove="RemovePanel"
               @ref="_panelRefs[current.Id]" />
    }
</div>

@code {
    private List<PanelModel> _panels = new();
    private Dictionary<Guid, Panel?> _panelRefs = new();
    private int _columns = 2;
    private int _panelSize = 500;

    private string? _statusMessage;
    private bool _statusIsError;
    private string _downloadUrl = "#";

    // auto-save on unload
    private DotNetObjectReference<PanelGrid>? _dotNetRef;

    // ── Lifecycle ─────────────────────────────────────────────────────────────

    protected override void OnInitialized()
    {
        _panels.Add(new PanelModel { Title = "Panel 1" });
        EnsurePanelRefKeys();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            _dotNetRef = DotNetObjectReference.Create(this);
            await JS.InvokeVoidAsync("ESLViewer.registerBeforeUnload", _dotNetRef);
        }
    }

    // ── Panel management ──────────────────────────────────────────────────────

    private void AddPanel(PanelType type)
    {
        var panel = new PanelModel { Title = $"Panel {_panels.Count + 1}", PanelType = type };
        _panels.Add(panel);
        _panelRefs[panel.Id] = null;
    }

    private void RemovePanel(PanelModel panel)
    {
        _panels.Remove(panel);
        _panelRefs.Remove(panel.Id);
    }

    /// Ensures every current panel has an entry in the refs dict (needed before first render).
    private void EnsurePanelRefKeys()
    {
        foreach (var p in _panels)
            _panelRefs.TryAdd(p.Id, null);
    }

    // ── Snapshot capture ──────────────────────────────────────────────────────

    private async Task<AppSnapshot> CaptureAppSnapshotAsync()
    {
        var panels = new List<PanelSnapshot>();
        foreach (var panel in _panels)
        {
            if (_panelRefs.TryGetValue(panel.Id, out var panelRef) && panelRef is not null)
                panels.Add(await panelRef.CaptureSnapshotAsync());
            else
                panels.Add(panel.ToSnapshot());
        }
        return new AppSnapshot
        {
            Version = "1.0",
            Columns = _columns,
            PanelSize = _panelSize,
            Panels = panels,
        };
    }

    // ── Snapshot apply ────────────────────────────────────────────────────────

    private async Task ApplyAppSnapshotAsync(AppSnapshot snapshot)
    {
        _panels.Clear();
        _panelRefs.Clear();
        _columns = snapshot.Columns;
        _panelSize = snapshot.PanelSize;

        foreach (var panelSnap in snapshot.Panels)
            _panels.Add(PanelModel.FromSnapshot(panelSnap));

        EnsurePanelRefKeys();

        // Yield so Blazor can re-render and populate the @ref dictionary.
        StateHasChanged();
        await Task.Delay(50);

        // Re-fetch data and restore axis ranges for every panel.
        for (var i = 0; i < _panels.Count; i++)
        {
            var panel = _panels[i];
            if (!_panelRefs.TryGetValue(panel.Id, out var panelRef) || panelRef is null) continue;

            await panelRef.RefreshAsync();

            var viewRect = snapshot.Panels[i].ViewRect;
            if (viewRect is not null)
                await panelRef.SetViewRect(viewRect);
        }
    }

    // ── Toolbar handlers ──────────────────────────────────────────────────────

    private async Task SaveToCookieAsync()
    {
        try
        {
            var snap = await CaptureAppSnapshotAsync();
            await StateService.SaveToCookieAsync(snap, JS);
            ShowStatus("Saved to cookie.");
        }
        catch (Exception ex) { ShowStatus($"Save failed: {ex.Message}", error: true); }
    }

    private async Task LoadFromCookieAsync()
    {
        try
        {
            var snap = await StateService.LoadFromCookieAsync(JS);
            if (snap is null) { ShowStatus("No saved state found in cookie.", error: true); return; }
            await ApplyAppSnapshotAsync(snap);
            ShowStatus("Loaded from cookie.");
        }
        catch (Exception ex) { ShowStatus($"Load failed: {ex.Message}", error: true); }
    }

    private async Task CopyToClipboardAsync()
    {
        try
        {
            var snap = await CaptureAppSnapshotAsync();
            await StateService.SaveToClipboardAsync(snap, JS);
            ShowStatus("Copied to clipboard.");
        }
        catch (Exception ex) { ShowStatus($"Copy failed: {ex.Message}", error: true); }
    }

    private async Task PasteFromClipboardAsync()
    {
        try
        {
            var snap = await StateService.LoadFromClipboardAsync(JS);
            if (snap is null) { ShowStatus("Clipboard does not contain valid state JSON.", error: true); return; }
            await ApplyAppSnapshotAsync(snap);
            ShowStatus("Loaded from clipboard.");
        }
        catch (Exception ex) { ShowStatus($"Paste failed: {ex.Message}", error: true); }
    }

    private async Task DownloadJsonAsync()
    {
        try
        {
            var snap = await CaptureAppSnapshotAsync();
            _downloadUrl = StateService.GetDownloadDataUrl(snap);
            StateHasChanged();
            await JS.InvokeVoidAsync("ESLViewer.clickElement", "state-download-link");
            ShowStatus("Download started.");
        }
        catch (Exception ex) { ShowStatus($"Download failed: {ex.Message}", error: true); }
    }

    private async Task LoadFromFileAsync(InputFileChangeEventArgs e)
    {
        try
        {
            var file = e.File;
            using var stream = file.OpenReadStream(maxAllowedSize: 1024 * 1024); // 1 MB limit
            using var reader = new System.IO.StreamReader(stream);
            var content = await reader.ReadToEndAsync();
            var snap = StateService.LoadFromFileContent(content);
            if (snap is null) { ShowStatus("File does not contain valid state JSON.", error: true); return; }
            await ApplyAppSnapshotAsync(snap);
            ShowStatus($"Loaded from \"{file.Name}\".");
        }
        catch (Exception ex) { ShowStatus($"File load failed: {ex.Message}", error: true); }
    }

    // ── auto-save on unload ───────────────────────────────────────────────────

    [JSInvokable]
    public async Task AutoSaveAsync()
    {
        try
        {
            var snap = await CaptureAppSnapshotAsync();
            await StateService.SaveToCookieAsync(snap, JS);
        }
        catch { /* best-effort — silently ignore */ }
    }

    // ── Helpers ───────────────────────────────────────────────────────────────

    private void ShowStatus(string message, bool error = false)
    {
        _statusMessage = message;
        _statusIsError = error;
        StateHasChanged();
        // Auto-clear after 4 s (fire-and-forget)
        _ = Task.Delay(4000).ContinueWith(_ =>
        {
            _statusMessage = null;
            InvokeAsync(StateHasChanged);
        });
    }

    // ── IAsyncDisposable ──────────────────────────────────────────────────────

    public async ValueTask DisposeAsync()
    {
        try { await JS.InvokeVoidAsync("ESLViewer.unregisterBeforeUnload"); } catch { }
        _dotNetRef?.Dispose();
    }
}

