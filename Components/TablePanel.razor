@using ESLViewer.Models
@inject MathServerService MathServer
@inject DragDropService DragDrop
@implements IAsyncDisposable

<div class="panel table-panel">
    <div class="panel-header">
        <span class="drag-handle" draggable="true"
              @ondragstart="OnDragStart" @ondragend="OnDragEnd"
              title="Drag to move panel">⠿</span>
        <input class="panel-title-input" type="text" @bind="Model.Title" @bind:event="oninput" />
        <span class="panel-header-spacer"></span>
        <label class="panel-ar-label">
            <input type="checkbox"
                   checked="@_ar.IsEnabled"
                   @onchange="OnAutoRefreshToggled" />
            Auto-refresh
        </label>
        @if (_ar.IsEnabled)
        {
            <select class="ar-select panel-ar-select" value="@_ar.Interval" @onchange="OnIntervalChanged">
                <option value="Second1">1 s</option>
                <option value="Seconds3">3 s</option>
                <option value="Seconds5">5 s</option>
                <option value="Seconds10">10 s</option>
                <option value="Minute1">1 min</option>
                <option value="Minute10">10 min</option>
                <option value="Hour1">1 hour</option>
            </select>
            <span class="ar-active-dot" title="Auto-refresh active"></span>
        }
        <span class="panel-type-badge">Table</span>
        <button class="btn-icon" title="Configure" @onclick="ToggleSetup">&#x2699;</button>
        <button class="btn-icon btn-danger" title="Remove panel" @onclick="() => OnRemove.InvokeAsync(Model)">&#x2715;</button>
    </div>

    @if (_showSetup)
    {
        <div class="dashboard-setup-panel">
            <div class="dashboard-setup-row">
                <label class="dashboard-setup-label">Command</label>
                <textarea class="dashboard-command-input expr-input"
                          placeholder="Enter server command…"
                          @bind="Model.Command"
                          @bind:event="oninput"></textarea>
                <button class="btn-sm btn-primary" @onclick="() => RefreshAsync()" title="Run command">&#8635;</button>
            </div>
        </div>
    }

    <div class="table-panel-view" @ondblclick="ToggleSetup">
        @if (_tableData.IsEmpty)
        {
            <span class="dashboard-placeholder">Double-click or ⚙ to configure…</span>
        }
        else
        {
            <table class="esl-table">
                <thead>
                    <tr>
                        @foreach (var col in _tableData.Columns)
                        {
                            <th>@col</th>
                        }
                    </tr>
                </thead>
                <tbody>
                    @foreach (var row in _tableData.Rows)
                    {
                        <tr>
                            <td class="esl-table-name">@row.Name</td>
                            @foreach (var val in row.Values)
                            {
                                <td class="esl-table-value">@val</td>
                            }
                        </tr>
                    }
                </tbody>
            </table>
        }
    </div>
</div>

@code {
    [Parameter] public TablePanelModel Model { get; set; } = default!;
    [Parameter] public EventCallback<PanelModel> OnRemove { get; set; }
    [Parameter] public EventCallback<PanelModel> OnReplaceWithEmpty { get; set; }

    // For test purposes: pre-populate with sample data
    private const string TestData =
        "[(\"name\", \"bid\", \"ask\"), (\"BTC\", 70000.3, 72000.4), (\"ETH\", 3040, 3400), (\"SOL\", 80, 90)]";

    private TableData _tableData = new();
    private bool _showSetup;

    // Auto-refresh controller
    private readonly AutoRefreshController _ar = new();

    protected override void OnInitialized()
    {
        _ar.Initialize(Model.AutoRefreshEnabled, Model.AutoRefreshInterval);
        // Pre-populate with test data so the table is visible immediately
        _tableData = TableDataParser.Parse(TestData);
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            if (!string.IsNullOrWhiteSpace(Model.Command))
                await RefreshAsync();
            if (_ar.IsEnabled)
                _ar.Start(_ => RefreshAsync());
        }
    }

    private void ToggleSetup() => _showSetup = !_showSetup;

    public async Task RefreshAsync(CancellationToken token = default)
    {
        if (string.IsNullOrWhiteSpace(Model.Command)) return;
        var raw = await MathServer.EvaluateRawAsync(Model.Command);
        if (!string.IsNullOrWhiteSpace(raw))
            _tableData = TableDataParser.Parse(raw);
        Model.AutoRefreshEnabled = _ar.IsEnabled;
        Model.AutoRefreshInterval = _ar.Interval;
        StateHasChanged();
    }

    // ── Auto-refresh ──────────────────────────────────────────────────────────

    private void OnAutoRefreshToggled(ChangeEventArgs e)
    {
        _ar.Toggle((bool)(e.Value ?? false), _ => RefreshAsync());
        Model.AutoRefreshEnabled = _ar.IsEnabled;
    }

    private void OnIntervalChanged(ChangeEventArgs e)
    {
        if (Enum.TryParse<AutoRefreshInterval>(e.Value?.ToString(), out var interval))
        {
            _ar.ChangeInterval(interval);
            Model.AutoRefreshInterval = _ar.Interval;
        }
    }

    // ── Drag ──────────────────────────────────────────────────────────────────

    private void OnDragStart()
        => DragDrop.StartDrag(Model, () => OnReplaceWithEmpty.InvokeAsync(Model));

    private void OnDragEnd()
    {
        if (DragDrop.IsDragging) DragDrop.Cancel();
    }

    // ── Snapshot ──────────────────────────────────────────────────────────────

    public PanelSnapshot CaptureSnapshot()
    {
        Model.AutoRefreshEnabled = _ar.IsEnabled;
        Model.AutoRefreshInterval = _ar.Interval;
        return Model.ToSnapshot();
    }

    public async ValueTask DisposeAsync()
    {
        await _ar.DisposeAsync();
    }
}

