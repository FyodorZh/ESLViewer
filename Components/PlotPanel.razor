@using ESLPlotter.Models
@using ESLPlotter.Services
@using ApexCharts
@inject MathServerService MathServer

<div class="plot-panel" style="width:@(Width)px; height:@(Height)px;">
    <div class="plot-header">
        <input class="plot-title-input" type="text" @bind="Plot.Title" @bind:event="oninput" />
        <button class="btn-icon btn-danger" title="Remove plot" @onclick="() => OnRemove.InvokeAsync(Plot)">&#x2715;</button>
    </div>

    <div class="plot-chart-area">
        @if (_loading)
        {
            <div class="plot-loading">Loading&#8230;</div>
        }
        @if (_error is not null)
        {
            <div class="plot-error">@_error</div>
        }

        <ApexChart TItem="PlotPoint"
                   Title=""
                   @ref="_chart"
                   Options="_options"
                   Width="@("100%")"
                   Height="@("100%")"
                   @key="_chartKey">
            @foreach (var expr in _enabledExpressions)
            {
                var e = expr;
                <ApexPointSeries TItem="PlotPoint"
                                 Items="e.Points"
                                 Name="@(string.IsNullOrWhiteSpace(e.Label) ? e.Expression : e.Label)"
                                 SeriesType="SeriesType.Line"
                                 XValue="p => (decimal)p.X"
                                 YValue="p => (decimal)p.Y"
                                 Color="@e.Color"
                                 OrderBy="d => d.X" />
            }
        </ApexChart>
    </div>

    <ExpressionEditor Expressions="Plot.Expressions"
                      OnRefresh="RefreshOneAsync"
                      OnColorChanged="UpdateChart" />
</div>

@code {
    [Parameter] public PlotModel Plot { get; set; } = default!;
    [Parameter] public int Width { get; set; } = 500;
    [Parameter] public int Height { get; set; } = 420;
    [Parameter] public EventCallback<PlotModel> OnRemove { get; set; }

    private ApexChart<PlotPoint>? _chart;
    private ApexChartOptions<PlotPoint> _options = new();
    private List<ExpressionModel> _enabledExpressions = new();
    private bool _loading;
    private string? _error;
    private int _prevWidth;
    private int _prevHeight;
    private int _chartKey;

    protected override void OnInitialized()
    {
        _prevWidth = Width;
        _prevHeight = Height;

        _options = new ApexChartOptions<PlotPoint>
        {
            Chart = new Chart
            {
                Zoom = new Zoom { Enabled = true, Type = AxisType.Xy },
                Toolbar = new Toolbar { Show = true, AutoSelected = AutoSelected.Zoom }
            },
            Xaxis = new XAxis { Type = XAxisType.Numeric },
            Stroke = new Stroke { Curve = Curve.Straight, Width = new List<int> { 2 } },
            Markers = new Markers { Size = new List<int> { 0 } },
            Legend = new Legend { Show = true, Position = LegendPosition.Bottom }
        };

        if (Plot.Expressions.Count == 0)
            Plot.Expressions.Add(new ExpressionModel { Expression = "x^2", Color = "#1b6ec2", Label = "f1" });
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
            await RefreshAsync();
    }

    protected override void OnParametersSet()
    {
        if (Width != _prevWidth || Height != _prevHeight)
        {
            _prevWidth = Width;
            _prevHeight = Height;
            _chartKey++;   // forces ApexChart to fully remount at the new container size
        }
    }

    // Called by ExpressionEditor: expr == null means refresh all
    private async Task RefreshOneAsync(ExpressionModel? expr)
    {
        if (expr is not null)
            await RefreshAsync(expr);
        else
            await RefreshAsync();
    }

    // Refresh a single expression only
    private async Task RefreshAsync(ExpressionModel expr)
    {
        _loading = true;
        _error = null;
        StateHasChanged();

        try
        {
            if (!string.IsNullOrWhiteSpace(expr.Expression))
                expr.Points = await MathServer.EvaluateAsync(expr.Expression);
        }
        catch (Exception ex)
        {
            _error = $"Error: {ex.Message}";
        }
        finally
        {
            _loading = false;
        }

        await UpdateChart();
    }

    // Refresh all expressions
    public async Task RefreshAsync()
    {
        _loading = true;
        _error = null;
        StateHasChanged();

        try
        {
            foreach (var expr in Plot.Expressions)
            {
                if (!string.IsNullOrWhiteSpace(expr.Expression))
                    expr.Points = await MathServer.EvaluateAsync(expr.Expression);
            }
        }
        catch (Exception ex)
        {
            _error = $"Error: {ex.Message}";
        }
        finally
        {
            _loading = false;
        }

        await UpdateChart();
    }

    private async Task UpdateChart()
    {
        _enabledExpressions = Plot.Expressions
            .Where(e => e.IsEnabled && e.Points.Count > 0)
            .ToList();

        StateHasChanged();

        if (_chart is not null)
            await _chart.RenderAsync();
    }
}
