@using ESLViewer.Models
@using ESLViewer.Models.State
@using ESLViewer.Services
@using ApexCharts
@inject MathServerService MathServer
@inject IJSRuntime JS
@implements IAsyncDisposable

<div class="plot-panel" style="width:@(Width)px; height:@(Height)px;">
    <div class="plot-header">
        <input class="plot-title-input" type="text" @bind="Plot.Title" @bind:event="oninput" />
        <span class="plot-type-badge">@Plot.PlotType</span>
        <button class="btn-icon btn-danger" title="Remove plot" @onclick="() => OnRemove.InvokeAsync(Plot)">&#x2715;</button>
    </div>

    <div class="plot-autorefresh-bar">
        <label class="ar-label">
            <input type="checkbox"
                   checked="@_autoRefreshEnabled"
                   @onchange="OnAutoRefreshToggled" />
            Auto-refresh
        </label>
        @if (_autoRefreshEnabled)
        {
            <select class="ar-select" value="@_autoRefreshInterval" @onchange="OnIntervalChanged">
                <option value="Seconds3">3 s</option>
                <option value="Seconds5">5 s</option>
                <option value="Seconds10">10 s</option>
                <option value="Minute1">1 min</option>
                <option value="Minute10">10 min</option>
                <option value="Hour1">1 hour</option>
            </select>
            <span class="ar-active-dot" title="Auto-refresh active"></span>
        }
    </div>

    <div class="plot-chart-area" id="chart-container-@Plot.Id">
        @if (_loading)
        {
            <div class="plot-loading">Loading&#8230;</div>
        }
        @if (_error is not null)
        {
            <div class="plot-error">@_error</div>
        }

        <ApexChart TItem="PlotPoint"
                   Title=""
                   @ref="_chart"
                   Options="_options"
                   Width="@("100%")"
                   Height="@("100%")"
                   @key="_chartKey">
            @if (Plot.PlotType == PlotType.DateTime)
            {
                @foreach (var expr in _enabledExpressions)
                {
                    var e = expr;
                    <ApexPointSeries TItem="PlotPoint"
                                     Items="e.Points"
                                     Name="@(string.IsNullOrWhiteSpace(e.Label) ? e.Expression : e.Label)"
                                     SeriesType="SeriesType.Line"
                                     XValue="p => (long)p.X"
                                     YValue="p => (decimal)p.Y"
                                     Color="@e.Color"
                                     OrderBy="d => d.X" />
                }
            }
            else
            {
                @foreach (var expr in _enabledExpressions)
                {
                    var e = expr;
                    <ApexPointSeries TItem="PlotPoint"
                                     Items="e.Points"
                                     Name="@(string.IsNullOrWhiteSpace(e.Label) ? e.Expression : e.Label)"
                                     SeriesType="SeriesType.Line"
                                     XValue="p => (decimal)p.X"
                                     YValue="p => (decimal)p.Y"
                                     Color="@e.Color"
                                     OrderBy="d => d.X" />
                }
            }
        </ApexChart>
    </div>

    <ExpressionEditor Expressions="Plot.Expressions"
                      PlotType="Plot.PlotType"
                      OnRefresh="RefreshOneAsync"
                      OnColorChanged="UpdateChart" />
</div>

@code {
    [Parameter] public PlotModel Plot { get; set; } = default!;
    [Parameter] public int Width { get; set; } = 500;
    [Parameter] public int Height { get; set; } = 420;
    [Parameter] public EventCallback<PlotModel> OnRemove { get; set; }

    private ApexChart<PlotPoint>? _chart;
    private ApexChartOptions<PlotPoint> _options = new();
    private List<ExpressionModel> _enabledExpressions = new();
    private bool _loading;
    private string? _error;
    private int _prevWidth;
    private int _prevHeight;
    private int _chartKey;
    private bool _needsChartRender;
    private bool _chartReady;

    // Auto-refresh
    private bool _autoRefreshEnabled;
    private AutoRefreshInterval _autoRefreshInterval = AutoRefreshInterval.Seconds5;
    private CancellationTokenSource? _cts;

    protected override void OnInitialized()
    {
        _prevWidth = Width;
        _prevHeight = Height;

        _options = new ApexChartOptions<PlotPoint>
        {
            Chart = new Chart
            {
                Zoom = new Zoom { Enabled = true, Type = AxisType.Xy },
                Toolbar = new Toolbar { Show = true, AutoSelected = AutoSelected.Zoom }
            },
            Xaxis = new XAxis
            {
                Type = Plot.PlotType == PlotType.DateTime ? XAxisType.Datetime : XAxisType.Numeric
            },
            Yaxis = new List<YAxis>
            {
                new YAxis
                {
                    Labels = new YAxisLabels
                    {
                        Formatter = "function(val) { return parseFloat(val.toPrecision(12)).toString(); }"
                    }
                }
            },
            Stroke = new Stroke { Curve = Curve.Straight, Width = new List<int> { 2 } },
            Markers = new Markers { Size = new List<int> { 0 } },
            Legend = new Legend { Show = true, Position = LegendPosition.Bottom }
        };

        if (Plot.Expressions.Count == 0)
        {
            var defaultExpr = Plot.PlotType == PlotType.DateTime ? string.Empty : "x^2";
            Plot.Expressions.Add(new ExpressionModel { Expression = defaultExpr, Color = "#1b6ec2", Label = "f1" });
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await RefreshAsync();
            // Mark the chart as ready only after the first full data load.
            // This prevents RenderAsync from firing before ApexCharts has
            // finished its own JS initialization.
            _chartReady = true;
        }
        else if (_needsChartRender && _chartReady)
        {
            _needsChartRender = false;
            if (_chart is not null)
                await _chart.RenderAsync();
        }
    }

    protected override void OnParametersSet()
    {
        if (Width != _prevWidth || Height != _prevHeight)
        {
            _prevWidth = Width;
            _prevHeight = Height;
            _chartKey++;   // forces ApexChart to fully remount at the new container size
        }
    }

    // Called by ExpressionEditor: expr == null means refresh all
    private async Task RefreshOneAsync(ExpressionModel? expr)
    {
        if (expr is not null)
            await RefreshAsync(expr);
        else
            await RefreshAsync();
    }

    // Refresh a single expression only
    private async Task RefreshAsync(ExpressionModel expr)
    {
        _loading = true;
        _error = null;
        StateHasChanged();

        try
        {
            if (!string.IsNullOrWhiteSpace(expr.Expression))
                expr.Points = await MathServer.EvaluateAsync(expr.Expression, Plot.PlotType);
        }
        catch (Exception ex)
        {
            _error = $"Error: {ex.Message}";
        }
        finally
        {
            _loading = false;
        }

        await UpdateChart();
    }

    // Refresh all expressions
    public async Task RefreshAsync()
    {
        _loading = true;
        _error = null;
        StateHasChanged();

        try
        {
            foreach (var expr in Plot.Expressions)
            {
                if (!string.IsNullOrWhiteSpace(expr.Expression))
                    expr.Points = await MathServer.EvaluateAsync(expr.Expression, Plot.PlotType);
            }
        }
        catch (Exception ex)
        {
            _error = $"Error: {ex.Message}";
        }
        finally
        {
            _loading = false;
        }

        await UpdateChart();
    }

    private async Task UpdateChart()
    {
        _enabledExpressions = Plot.Expressions
            .Where(e => e.IsEnabled && e.Points.Count > 0)
            .ToList();

        _needsChartRender = true;
        StateHasChanged();

        // Immediate call handles the hide case (series must be removed from the
        // chart before / during the Blazor re-render cycle).
        if (_chart is not null && _chartReady)
            await _chart.RenderAsync();
    }

    // ── Auto-refresh ──────────────────────────────────────────────────────────

    private void OnAutoRefreshToggled(ChangeEventArgs e)
    {
        _autoRefreshEnabled = (bool)(e.Value ?? false);
        if (_autoRefreshEnabled)
            StartAutoRefreshLoop();
        else
            StopAutoRefresh();
    }

    private void OnIntervalChanged(ChangeEventArgs e)
    {
        if (Enum.TryParse<AutoRefreshInterval>(e.Value?.ToString(), out var interval))
            _autoRefreshInterval = interval;

        if (_autoRefreshEnabled)
        {
            StopAutoRefresh();
            StartAutoRefreshLoop();
        }
    }

    private TimeSpan GetRefreshTimeSpan() => _autoRefreshInterval switch
    {
        AutoRefreshInterval.Seconds3  => TimeSpan.FromSeconds(3),
        AutoRefreshInterval.Seconds5  => TimeSpan.FromSeconds(5),
        AutoRefreshInterval.Seconds10 => TimeSpan.FromSeconds(10),
        AutoRefreshInterval.Minute1   => TimeSpan.FromMinutes(1),
        AutoRefreshInterval.Minute10  => TimeSpan.FromMinutes(10),
        AutoRefreshInterval.Hour1     => TimeSpan.FromHours(1),
        _                             => TimeSpan.FromSeconds(5)
    };

    private void StartAutoRefreshLoop()
    {
        StopAutoRefresh();
        _cts = new CancellationTokenSource();
        _ = AutoRefreshLoopAsync(_cts.Token);
    }

    private async Task AutoRefreshLoopAsync(CancellationToken token)
    {
        using var timer = new PeriodicTimer(GetRefreshTimeSpan());
        try
        {
            while (await timer.WaitForNextTickAsync(token))
                await RefreshAsync();
        }
        catch (OperationCanceledException) { }
    }

    private void StopAutoRefresh()
    {
        _cts?.Cancel();
        _cts?.Dispose();
        _cts = null;
    }

    // ── Snapshot / ViewRect interop ───────────────────────────────────────────

    /// <summary>
    /// Reads the current chart zoom/pan range via JS interop.
    /// Returns a ViewRect whose fields are null when the axis is at auto-scale.
    /// </summary>
    public async Task<ViewRect> GetViewRect()
    {
        try
        {
            var result = await JS.InvokeAsync<ViewRect?>(
                "ESLViewer.getChartAxisRange", $"chart-container-{Plot.Id}");
            return result ?? new ViewRect();
        }
        catch
        {
            return new ViewRect();
        }
    }

    /// <summary>
    /// Restores the chart zoom/pan range via JS interop.
    /// Null fields in <paramref name="rect"/> leave the corresponding axis at auto-scale.
    /// </summary>
    public async Task SetViewRect(ViewRect rect)
    {
        try
        {
            await JS.InvokeVoidAsync(
                "ESLViewer.setChartAxisRange",
                $"chart-container-{Plot.Id}",
                rect.XMin, rect.XMax,
                rect.YMin, rect.YMax);
        }
        catch { /* chart may not be ready — silently ignore */ }
    }

    /// <summary>
    /// Captures the full persistable state for this plot, including the
    /// current chart axis range obtained via JS interop.
    /// </summary>
    public async Task<PlotSnapshot> CaptureSnapshotAsync()
    {
        var snapshot = Plot.ToSnapshot();
        snapshot.ViewRect = await GetViewRect();
        return snapshot;
    }

    public ValueTask DisposeAsync()

    {
        StopAutoRefresh();
        return ValueTask.CompletedTask;
    }
}