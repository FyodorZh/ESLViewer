@using ESLViewer.Models
@using System.Globalization
@using System.Numerics

<div class="expr-panel">
    @foreach (var expr in Expressions)
    {
        var current = expr;
        <div class="expr-row">
            <input class="expr-color"
                   type="color"
                   value="@current.Color"
                   title="Series color"
                   @oninput="e => { current.Color = e.Value?.ToString() ?? current.Color; OnColorChanged.InvokeAsync(); }" />
            <textarea class="expr-input"
                      placeholder="@Placeholder"
                      @oninput="e => current.Expression = e.Value?.ToString() ?? string.Empty"
                      @onkeydown="e => OnKeyDown(e, current)">@current.Expression</textarea>
            <input class="expr-toggle"
                   type="checkbox"
                   checked="@current.IsEnabled"
                   title="Show/hide series"
                   @onchange="e => { current.IsEnabled = (bool)(e.Value ?? true); OnColorChanged.InvokeAsync(); }" />
            <button class="btn-icon btn-danger" title="Remove" @onclick="() => Remove(current)">&#x2715;</button>
        </div>
    }

    @if (Parameters.Count > 0)
    {
        <div class="param-section">
            @foreach (var param in Parameters)
            {
                var p = param;
                <div class="param-row">
                    <input class="param-name-input" type="text"
                           value="@p.Name"
                           title="Parameter name — use {Name} in expressions"
                           @oninput="e => p.Name = e.Value?.ToString() ?? p.Name" />
                    <input class="param-num-input" type="number"
                           value="@p.Min.ToString("G6", CultureInfo.InvariantCulture)"
                           title="Minimum"
                           @oninput="e => { p.Min = ParseDouble(e.Value?.ToString(), p.Min); ClampParamValue(p); }" />
                    <input class="param-slider" type="range"
                           min="@p.Min.ToString("G", CultureInfo.InvariantCulture)"
                           max="@p.Max.ToString("G", CultureInfo.InvariantCulture)"
                           step="any"
                           value="@p.Value.ToString("G", CultureInfo.InvariantCulture)"
                           @oninput="e => OnSliderChanged(e, p)" />
                    <input class="param-num-input" type="number"
                           value="@p.Max.ToString("G6", CultureInfo.InvariantCulture)"
                           title="Maximum"
                           @oninput="e => { p.Max = ParseDouble(e.Value?.ToString(), p.Max); ClampParamValue(p); }" />
                    <span class="param-value-display" title="Current value">@p.Value.ToString("G6", CultureInfo.InvariantCulture)</span>
                    <button class="btn-icon btn-danger" title="Remove parameter" @onclick="() => RemoveParameter(p)">&#x2715;</button>
                </div>
            }
        </div>
    }

    <div class="expr-actions">
        <button class="btn-sm btn-secondary" @onclick="AddExpression">+ Add expression</button>
        <button class="btn-sm btn-secondary" @onclick="AddParameter">+ Add parameter</button>
        <button class="btn-sm btn-primary" @onclick="() => OnRefresh.InvokeAsync(null)">&#8635; Refresh</button>
    </div>
</div>

@code {
    [Parameter] public List<ExpressionModel> Expressions { get; set; } = new();
    [Parameter] public List<ParameterModel> Parameters { get; set; } = new();
    [Parameter] public EventCallback<ExpressionModel?> OnRefresh { get; set; }
    [Parameter] public EventCallback OnColorChanged { get; set; }
    [Parameter] public PanelType PanelType { get; set; } = PanelType.Numeric;

    private string Placeholder => PanelType switch
    {
        PanelType.DateTime => "e.g. TestDates()",
        _ => "e.g. TestNumeric()"
    };

    private static readonly string[] DefaultColors =
    {
        "#1b6ec2", "#e03030", "#28a745", "#fd7e14",
        "#6f42c1", "#20c997", "#dc3545", "#0dcaf0"
    };

    private void AddExpression()
    {
        var color = DefaultColors[Expressions.Count % DefaultColors.Length];
        Expressions.Add(new ExpressionModel { Color = color, Label = $"f{Expressions.Count + 1}" });
    }

    private void Remove(ExpressionModel expr)
    {
        Expressions.Remove(expr);
        OnRefresh.InvokeAsync(null);
    }

    private void OnKeyDown(KeyboardEventArgs e, ExpressionModel expr)
    {
        if (e.Key == "Enter" && !e.ShiftKey)
            OnRefresh.InvokeAsync(expr);
    }

    private void AddParameter()
    {
        var n = Parameters.Count + 1;
        while (Parameters.Any(p => p.Name == $"Param{n}")) n++;
        Parameters.Add(new ParameterModel { Name = $"Param{n}", Min = 0, Max = 100, Value = 50 });
    }

    private void RemoveParameter(ParameterModel param)
    {
        Parameters.Remove(param);
        OnRefresh.InvokeAsync(null);
    }

    private async Task OnSliderChanged(ChangeEventArgs e, ParameterModel param)
    {
        param.Value = ParseDouble(e.Value?.ToString(), param.Value);
        await OnRefresh.InvokeAsync(null);
    }

    private static void ClampParamValue(ParameterModel param)
    {
        if (param.Value < param.Min) param.Value = param.Min;
        if (param.Value > param.Max) param.Value = param.Max;
    }

    private static double ParseDouble(string? s, double fallback) =>
        double.TryParse(s, NumberStyles.Any, CultureInfo.InvariantCulture, out var v) ? v : fallback;
}